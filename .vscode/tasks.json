{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mvn: test",
      "type": "shell",
      "command": "./mvnw",
      "args": [
        "test"
      ],
      "windows": {
        "command": "mvnw.cmd",
        "args": [
          "test"
        ]
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "mvn: package",
      "type": "shell",
      "command": "./mvnw",
      "args": [
        "-q",
        "package",
        "-DskipTests"
      ],
      "windows": {
        "command": "mvnw.cmd",
        "args": [
          "-q",
          "package",
          "-DskipTests"
        ]
      }
    }
  ]
}
